{
    "command": "{{HOME}}/firefox_bin/firefox",
    "argv": [],
    "workdir": "{{HOME}}",
    "share_tmp": true,
    "debug": false,
    "desktop_app": true,
    "minimal_dbus": true,
    "use_net": true,
    "dbus_talk": [
        "org.freedesktop.portal.Desktop",
        "org.freedesktop.portal.Documents"
    ],
    "dbus_see": [
        "org.freedesktop.portal.Desktop",
        "org.freedesktop.portal.Documents"
    ],
    "env" : [
        ["NO_AT_BRIDGE", "1"]
    ],

    "bind" : [
        "{{HOME}}/firefox_bin",
        "{{XDG_RUNTIME_DIR}}/pulse",
        "{{XDG_RUNTIME_DIR}}/pipewire-0"
    ]
}
